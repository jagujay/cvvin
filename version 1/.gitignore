# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files
# NOTE: .env files are NOT ignored - they should be committed for dev setup
# Only ignore local environment files that might contain sensitive overrides
*.local
!backend/.env
!frontend/.env
backend/.env.local
frontend/.env.local

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# Uploads (user-generated content)
backend/uploads/users/*/
!backend/uploads/users/.gitkeep

# Lock files (optional - uncomment if you don't want to commit lock files)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# bun.lockb

# Testing
coverage/
.nyc_output/
*.test.js.snap

# Temporary files
*.tmp
*.temp
.cache/