// ============================================================================
// CVVIN Platform — Prisma Schema
// ============================================================================
// Unified schema reverse-engineered from legacy SQL migrations (v1) and
// extended to support Admin Dashboard, question banks, and AI evaluation.
//
// Conventions:
//   • Models use PascalCase, fields use camelCase
//   • Every model maps to its legacy snake_case table via @map
//   • UUIDs for PKs on legacy tables (preserve existing data)
//   • CUIDs for PKs on new tables (better k-sortable IDs)
//   • JSON fields for flexible / AI-generated data
//   • Enums replace free-form VARCHAR columns
// ============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum UserRole {
  STUDENT
  ADMIN
  PROCTOR

  @@map("user_role")
}

enum SessionType {
  FULL_MOCK
  TECHNICAL
  HR
  RESUME

  @@map("session_type")
}

enum SessionStatus {
  ACTIVE
  IN_PROGRESS
  COMPLETED
  ABANDONED

  @@map("session_status")
}

enum ComponentType {
  RESUME_ANALYSIS
  MCQ
  CODING
  HR

  @@map("component_type")
}

enum FileType {
  RESUME_PDF
  PROFILE_IMAGE
  DOCUMENT
  AUDIO

  @@map("file_type")
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED

  @@map("processing_status")
}

enum ViolationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("violation_severity")
}

// ──────────────────────────────────────────────
// Models — Legacy (UUID PKs, @map to existing tables)
// ──────────────────────────────────────────────

/// Core user identity, synced from Firebase Auth.
model User {
  id              String    @id @default(uuid()) @db.Uuid
  firebaseUid     String    @unique @map("firebase_uid") @db.VarChar(128)
  email           String    @unique @db.VarChar(255)
  firstName       String?   @map("first_name") @db.VarChar(100)
  lastName        String?   @map("last_name") @db.VarChar(100)
  phone           String?   @db.VarChar(20)
  profileImageUrl String?   @map("profile_image_url")
  role            UserRole  @default(STUDENT)
  isActive        Boolean   @default(true) @map("is_active")
  preferences     Json      @default("{}")
  lastLogin       DateTime? @map("last_login")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  profile           UserProfile?
  files             File[]
  resumeAnalyses    ResumeAnalysis[]
  interviewSessions InterviewSession[]

  @@index([firebaseUid])
  @@index([email])
  @@map("users")
}

/// Extended profile data — 1:1 with User.
/// JSONB arrays for skills, education, etc. to match legacy schema.
model UserProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  resumeUrl       String?  @map("resume_url")
  resumeText      String?  @map("resume_text")
  skills          Json     @default("[]")
  experienceYears Decimal? @map("experience_years") @db.Decimal(3, 1)
  education       Json     @default("[]")
  certifications  Json     @default("[]")
  languages       Json     @default("[]")
  targetRoles     Json     @default("[]") @map("target_roles")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_profiles")
}

/// File metadata. Binary data is NOT stored in the database —
/// files live on the filesystem (or future S3). The legacy BYTEA
/// column `file_data` is intentionally dropped.
model File {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  fileName         String           @map("file_name") @db.VarChar(255)
  fileType         FileType         @map("file_type")
  fileSize         BigInt           @map("file_size")
  filePath         String?          @map("file_path")
  storageMethod    String           @default("filesystem") @map("storage_method") @db.VarChar(20)
  mimeType         String?          @map("mime_type") @db.VarChar(100)
  uploadDate       DateTime         @default(now()) @map("upload_date")
  isProcessed      Boolean          @default(false) @map("is_processed")
  processingStatus ProcessingStatus @default(PENDING) @map("processing_status")
  checksum         String?          @db.VarChar(64)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeAnalyses ResumeAnalysis[]

  @@index([userId])
  @@index([storageMethod])
  @@index([fileType])
  @@index([checksum])
  @@map("files")
}

/// AI-powered resume analysis results.
model ResumeAnalysis {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  fileId         String   @map("file_id") @db.Uuid
  jobDescription String   @map("job_description")
  analysisResult Json     @map("analysis_result")
  overallScore   Int?     @map("overall_score")
  resumeText     String?  @map("resume_text")
  analysisDate   DateTime @default(now()) @map("analysis_date")
  modelVersion   String   @default("resume-analyzer-v1") @map("model_version") @db.VarChar(50)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fileId])
  @@index([analysisDate])
  @@map("resume_analyses")
}

/// Top-level interview session container.
model InterviewSession {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  sessionType   SessionType   @map("session_type")
  status        SessionStatus @default(ACTIVE)
  startedAt     DateTime      @default(now()) @map("started_at")
  completedAt   DateTime?     @map("completed_at")
  totalDuration Int?          @map("total_duration") // seconds
  overallScore  Int?          @map("overall_score")
  feedback      Json          @default("{}")
  metadata      Json          @default("{}")

  // Relations
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  components           SessionComponent[]
  proctoringViolations ProctoringViolation[]

  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@map("interview_sessions")
}

/// Individual assessment component within a session (MCQ round, Coding round, etc.).
model SessionComponent {
  id            String        @id @default(uuid()) @db.Uuid
  sessionId     String        @map("session_id") @db.Uuid
  componentType ComponentType @map("component_type")
  componentData Json          @map("component_data")
  score         Int?
  completedAt   DateTime?     @map("completed_at")
  feedback      Json          @default("{}")

  // Relations
  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, componentType])
  @@index([sessionId])
  @@index([componentType])
  @@map("session_components")
}

/// Proctoring violation events captured during a session.
model ProctoringViolation {
  id            String            @id @default(uuid()) @db.Uuid
  sessionId     String            @map("session_id") @db.Uuid
  violationType String            @map("violation_type") @db.VarChar(100)
  details       String?
  severity      ViolationSeverity
  timestamp     DateTime          @db.Timestamptz
  metadata      Json              @default("{}")
  count         Int               @default(1)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([timestamp])
  @@index([violationType])
  @@index([severity])
  @@map("proctoring_violations")
}

// ──────────────────────────────────────────────
// Models — New (CUID PKs, first-class question banks)
// ──────────────────────────────────────────────

/// MCQ question bank for technical assessments.
/// `orGroupId` allows grouping questions for OR-based scoring logic.
model McqQuestion {
  id            String   @id @default(cuid())
  question      String
  options       Json // Array of option strings
  correctAnswer Int      @map("correct_answer") // 0-based index into options
  difficulty    String   @default("medium") @db.VarChar(20) // easy, medium, hard
  category      String   @default("general") @db.VarChar(100)
  orGroupId     String?  @map("or_group_id")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([difficulty])
  @@index([orGroupId])
  @@map("mcq_questions")
}

/// Coding challenge bank for technical assessments.
/// `orGroupId` allows grouping problems for OR-based scoring logic.
model CodingChallenge {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(255)
  description String
  difficulty  String   @default("medium") @db.VarChar(20)
  testCases   Json     @map("test_cases") // Array of { input, expectedOutput }
  constraints Json     @default("{}") // Time/space complexity constraints
  starterCode Json     @default("{}") @map("starter_code") // { language: code } map
  orGroupId   String?  @map("or_group_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([difficulty])
  @@index([orGroupId])
  @@map("coding_challenges")
}

/// HR question bank for behavioral interview assessments.
/// `orGroupId` allows grouping questions for OR-based scoring logic.
model HrQuestion {
  id             String   @id @default(cuid())
  question       String
  category       String   @default("general") @db.VarChar(100)
  expectedTopics Json     @default("[]") @map("expected_topics") // Topics the answer should cover
  difficulty     String   @default("medium") @db.VarChar(20)
  orGroupId      String?  @map("or_group_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([difficulty])
  @@index([orGroupId])
  @@map("hr_questions")
}
