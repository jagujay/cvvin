{
  "manifest_version": 3,
  "name": "Enhanced Proctoring System",
  "version": "2.0",
  "description": "Advanced monitoring for proctoring with app-switch detection, keyboard shortcuts, and activity tracking.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "windows",
    "alarms",
    "downloads",
    "history",
    "management",
    "system.display",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://localhost:8080/*"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
